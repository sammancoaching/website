#!/usr/bin/env bash
set -euo pipefail

# In some environments (e.g. remote dev containers) the gem bin directory
# is not on PATH, which makes `bundle exec jekyll` fail with "command not found".
export PATH="$(ruby -e 'print Gem.bindir'):$PATH"

bundle install

if [ "${1:-}" == "prod" ]; then
    export JEKYLL_ENV=production
fi

bundle exec jekyll serve --livereload --host 0.0.0.0
